/**
 * This library provides two services: direct access to the computer's main
 * memory (RAM), and allocation and recycling of memory blocks. The Hack RAM
 * consists of 32,768 words, each holding a 16-bit binary number.
 */
class Memory {
    static Array ram;
    static int freeList;

    /** Initializes the class. */
    function void init() {
        let ram = 0;
        let freeList = 2048;
        let ram[2048] = 14336;
        let ram[2049] = 0;
        return;
    }

    /** Returns the RAM value at the given address. */
    function int peek(int address) {
        return ram[address];
    }

    /** Sets the RAM value at the given address to the given value. */
    function void poke(int address, int value) {
        let ram[address] = value;
        return;
    }

    /** Finds an available RAM block of the given size and returns
     *  a reference to its base address. */
    function int alloc(int size) {
        var int remainder;
        var int currSegment;
        var int prevSegment;

        let prevSegment = 0;
        let currSegment = freeList;

        while (ram[currSegment] < size + 3) {
            if (currSegment = 0) {
                do Sys.error("Out of memory");
            }
            let prevSegment = currSegment;
            let currSegment = ram[currSegment + 1];
        }

        if (currSegment = 0) {
            return -1;
        }


        let remainder = currSegment + size + 2;
        let ram[remainder] = ram[currSegment] - (size + 2);
        let ram[remainder + 1] = ram[currSegment + 1];

        if (prevSegment = 0) {
            let freeList = remainder;
        } else {
            let ram[prevSegment + 1] = remainder;
        }

        return currSegment + 2;
    }

    /** De-allocates the given object (cast as an array) by making
     *  it available for future allocations. */
    function void deAlloc(Array o) {
        var int segment;

        let segment = o - 2;
        let ram[segment + 1] = freeList;
        let freeList = segment;
        return;
    }
}
